00D1A:  MOVLW  01
00D1C:  MOVWF  FD1
00D1E:  MOVLW  07
00D20:  MOVWF  FCE
00D22:  CLRF   FCF
00D24:  CLRF   FD0
....................    timeoutReg0 = 0;  // clear all the timers
00D26:  MOVLB  1
00D28:  CLRF   x75
00D2A:  CLRF   x74
00D2C:  CLRF   x73
00D2E:  CLRF   x72
....................    timeoutReg1 = 0;
00D30:  CLRF   x79
00D32:  CLRF   x78
00D34:  CLRF   x77
00D36:  CLRF   x76
....................    timeoutReg2 = 0;
00D38:  CLRF   x7D
00D3A:  CLRF   x7C
00D3C:  CLRF   x7B
00D3E:  CLRF   x7A
.................... //!   intTimeoutReg = 50;
