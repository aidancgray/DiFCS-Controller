0067C:  MOVLW  01
0067E:  MOVWF  x1A
00680:  MOVLB  0
00682:  RCALL  040A
....................    delay_ms(1);
00684:  MOVLW  01
00686:  MOVLB  7
00688:  MOVWF  x25
0068A:  MOVLB  0
0068C:  RCALL  045C
....................    if (paramsValid != isValid)
0068E:  MOVF   xFA,W
00690:  SUBLW  AA
00692:  BZ    069C
....................    {
....................       paramsValid = isValid;
00694:  MOVLW  AA
00696:  MOVWF  xFA
....................       params_save_to_ee(); // saves the base parameters on first boot
00698:  RCALL  04EC
....................    }
0069A:  BRA    069E
....................    else
....................    {
....................       params_load_from_ee();
0069C:  BRA    05CE
....................    }
0069E:  GOTO   B1AA (RETURN)
.................... }
.................... 
.................... /*****************************************************************************/
.................... /* INVALIDATE PARAMS -- Restarting will load defauts                         */
.................... /*****************************************************************************/
.................... void params_invalidate()
.................... {
....................    paramsValid = invalidate;
....................    ee_save_reg(&paramsValid, params_valid_ee_addr, params_valid_length);
.................... }
.................... 
.................... #endif
